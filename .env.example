# Frontend endpoint (Google Apps Script Web App URL)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-web-app-id/exec

# Google OAuth / API (public client metadata)
VITE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_CLIENT_SECRET=your-google-client-secret
VITE_API_KEY=your-google-api-key
VITE_SHEET_ID=your-google-sheet-id

# Backend/server-side only secrets (never expose real values in git)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}
GOOGLE_SHEET_ID=your-google-sheet-id
